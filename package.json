{
  "name": "photolyze",
  "version": "0.1.0",
  "type": "module",
  "description": "Data-driven, programmatically controllable interactive SVG visualization of laser–tissue absorption spectra. Engine/data separated.",
  "license": "MIT",
  "main": "lib/photolyze.umd.cjs",
  "module": "lib/photolyze.js",
  "types": "src/index.ts",
  "files": ["lib", "src", "data", "README.md"],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp -R data dist/data",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "data": "node scripts/build_dataset.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
